{
  "$ref": "#/definitions/RunMeta",
  "definitions": {
    "RunMeta": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "generated_at": {
          "type": "string"
        },
        "exporter_version": {
          "type": "string"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "dataset_changed": {
          "type": "boolean"
        },
        "validation_passed": {
          "type": "boolean"
        },
        "degraded": {
          "type": "boolean"
        },
        "degraded_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "staged": {
          "type": "boolean"
        },
        "commit_created": {
          "type": "boolean"
        },
        "push_succeeded": {
          "type": "boolean"
        },
        "published": {
          "type": "boolean"
        },
        "enumeration": {
          "type": "object",
          "properties": {
            "source": {
              "type": "string",
              "enum": [
                "graphql",
                "rest-fallback"
              ]
            },
            "is_over_limit": {
              "type": "boolean"
            },
            "reported": {
              "type": "integer",
              "minimum": 0
            },
            "enumerated": {
              "type": "integer",
              "minimum": 0
            },
            "duplicates": {
              "type": "integer",
              "minimum": 0
            },
            "duplicate_conflicts": {
              "type": "integer",
              "minimum": 0
            },
            "restarted": {
              "type": "boolean"
            }
          },
          "required": [
            "source",
            "is_over_limit",
            "reported",
            "enumerated",
            "duplicates",
            "duplicate_conflicts",
            "restarted"
          ],
          "additionalProperties": false
        },
        "counts": {
          "type": "object",
          "properties": {
            "exported": {
              "type": "integer",
              "minimum": 0
            },
            "private_filtered": {
              "type": "integer",
              "minimum": 0
            },
            "removed_mid_run": {
              "type": "integer",
              "minimum": 0
            },
            "dropped_unidentifiable": {
              "type": "integer",
              "minimum": 0
            },
            "hydration_failed_publishable": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "exported",
            "private_filtered",
            "removed_mid_run",
            "dropped_unidentifiable",
            "hydration_failed_publishable"
          ],
          "additionalProperties": false
        },
        "github_api": {
          "type": "object",
          "properties": {
            "graphql": {
              "type": "object",
              "properties": {
                "requests": {
                  "type": "integer",
                  "minimum": 0
                },
                "cost": {
                  "type": "integer",
                  "minimum": 0
                },
                "remaining": {
                  "type": "integer",
                  "minimum": 0
                },
                "reset_at": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "required": [
                "requests",
                "cost",
                "remaining",
                "reset_at"
              ],
              "additionalProperties": false
            },
            "rest": {
              "type": "object",
              "properties": {
                "requests": {
                  "type": "integer",
                  "minimum": 0
                },
                "remaining": {
                  "anyOf": [
                    {
                      "type": "integer"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "reset_at": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "required": [
                "requests",
                "remaining",
                "reset_at"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "graphql",
            "rest"
          ],
          "additionalProperties": false
        },
        "retry": {
          "type": "object",
          "properties": {
            "attempts": {
              "type": "integer",
              "minimum": 0
            },
            "total_wait_ms": {
              "type": "integer",
              "minimum": 0
            },
            "secondary_limit_events": {
              "type": "integer",
              "minimum": 0
            },
            "global_cooldowns": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "attempts",
            "total_wait_ms",
            "secondary_limit_events",
            "global_cooldowns"
          ],
          "additionalProperties": false
        },
        "hydrate": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "integer",
              "minimum": 0
            },
            "initial_batches": {
              "type": "integer",
              "minimum": 0
            },
            "bisections": {
              "type": "integer",
              "minimum": 0
            },
            "max_bisection_depth": {
              "type": "integer",
              "minimum": 0
            },
            "singleton_failures": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "requests",
            "initial_batches",
            "bisections",
            "max_bisection_depth",
            "singleton_failures"
          ],
          "additionalProperties": false
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message"
            ],
            "additionalProperties": false
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "schema_version",
        "generated_at",
        "exporter_version",
        "duration_ms",
        "dataset_changed",
        "validation_passed",
        "degraded",
        "degraded_ratio",
        "staged",
        "commit_created",
        "push_succeeded",
        "published",
        "enumeration",
        "counts",
        "github_api",
        "retry",
        "hydrate",
        "warnings",
        "errors"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "https://json-schema.org/draft/2019-09/schema#"
}
